{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/growth/layout,_N_T_/growth/performance/layout,_N_T_/growth/performance/page,_N_T_/growth/performance"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/growth/performance/__PAGE__",
    "/growth/performance",
    "/growth",
    "/_index",
    "/_head"
  ]
}