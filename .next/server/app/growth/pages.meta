{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/growth/layout,_N_T_/growth/pages/layout,_N_T_/growth/pages/page,_N_T_/growth/pages"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/growth/pages/__PAGE__",
    "/growth/pages",
    "/growth",
    "/_index",
    "/_head"
  ]
}