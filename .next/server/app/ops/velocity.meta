{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/ops/layout,_N_T_/ops/velocity/layout,_N_T_/ops/velocity/page,_N_T_/ops/velocity"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/ops/velocity/__PAGE__",
    "/ops/velocity",
    "/ops",
    "/_index",
    "/_head"
  ]
}